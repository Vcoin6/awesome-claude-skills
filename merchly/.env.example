# ──────────────────────────────────────────────────────────────
# Merchly environment configuration
# Copy this file to `.env.local` and fill in real values for production.
# Merchly runs fully in DEMO mode with zero config — these are optional.
# ──────────────────────────────────────────────────────────────

# Secret used to sign auth (JWT) cookies. Change this in production.
AUTH_SECRET=change-me-to-a-long-random-string

# Platform commission charged to sellers on every sale (percent).
# 5% goes to the app owner, the seller keeps the remaining 95%.
PLATFORM_FEE_PERCENT=5

# ── Stripe Connect (optional — enables REAL money movement) ──
# When these are present, Merchly switches from simulation to real payments
# using Stripe Connect "separate charges and transfers":
#   1. The buyer is charged ONCE for the whole cart on your platform account.
#   2. On payment success (via the webhook), each seller is paid their 95% with
#      a Stripe Transfer to their connected account. Your platform keeps the 5%.
# Leave blank to run the built-in payment SIMULATION (great for demos/testing).
#
# Get your keys at https://dashboard.stripe.com/apikeys (use test keys first).
STRIPE_SECRET_KEY=sk_test_xxx
# The publishable key MUST be prefixed NEXT_PUBLIC_ so the browser can load it.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Webhook signing secret. Locally: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Production storage (Vercel) ──
# Serverless filesystems are read-only/ephemeral, so production needs real
# storage. Merchly auto-detects these — locally it falls back to a JSON file
# (data/) and the public/uploads folder, so dev stays zero-config.
#
# Vercel KV (data) — create from the Vercel dashboard → Storage → KV. Vercel
# injects these automatically when the KV store is linked to the project:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Vercel Blob (media uploads) — create from Storage → Blob; injected on link:
BLOB_READ_WRITE_TOKEN=
