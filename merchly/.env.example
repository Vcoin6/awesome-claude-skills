# ──────────────────────────────────────────────────────────────
# Merchly environment configuration
# Copy this file to `.env.local` and fill in real values for production.
# Merchly runs fully in DEMO mode with zero config — these are optional.
# ──────────────────────────────────────────────────────────────

# Secret used to sign auth (JWT) cookies. Change this in production.
AUTH_SECRET=change-me-to-a-long-random-string

# Platform commission charged to sellers on every sale (percent).
# 5% goes to the app owner, the seller keeps the remaining 95%.
PLATFORM_FEE_PERCENT=5

# ── Stripe Connect (optional — enables REAL money movement) ──
# When these are present, Merchly uses Stripe Connect "destination charges":
# the buyer is charged, your platform automatically keeps the 5% application
# fee, and the remaining 95% is transferred to the seller's connected account.
# Leave blank to run the built-in payment SIMULATION (great for demos/testing).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Your platform's Stripe account is the destination for the 5% fee
# (configured automatically by your STRIPE_SECRET_KEY account).
